{
  "expo": {
    "name": "MedicationApp",
    "slug": "MedicationApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon_1773011981123.png",
    "scheme": "medicationapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#173663",
        "foregroundImage": "./assets/images/app_icon_1773011981123.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.abdelrahman_mohamed123.MedicationApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash_screen_1773011993293.png",
          "imageWidth": 800,
          "resizeMode": "contain",
          "backgroundColor": "#0A1628",
          "dark": {
            "image": "./assets/images/splash_screen_1773011993293.png",
            "backgroundColor": "#0A1628"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4F8EF7",
          "defaultChannel": "medication",
          "androidMode": "default",
          "androidCollapsedTitle": "Medication Reminders"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edf32320-72b1-480d-9e50-e39bf6b198a4"
      }
    }
  }
}
